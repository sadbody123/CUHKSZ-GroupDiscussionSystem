# Streamlit UI — points at API via UI_API_BASE_URL.
FROM python:3.11-slim

WORKDIR /app

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    UI_API_BASE_URL=http://api:8000

COPY pyproject.toml README.md ./
COPY app ./app

RUN pip install --upgrade pip && pip install -e ".[dev]"

EXPOSE 8501

CMD ["streamlit", "run", "app/ui/streamlit_app.py", "--server.address", "0.0.0.0", "--server.port", "8501", "--server.headless", "true", "--browser.gatherUsageStats", "false"]
