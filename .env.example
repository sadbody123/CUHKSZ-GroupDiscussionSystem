# Optional: override default snapshot root (relative to project root)
# SNAPSHOT_ROOT=app/knowledge/snapshots

# Optional: default chunk size for evidence chunker
# CHUNK_SIZE=600
# CHUNK_OVERLAP=80

# Logging
# LOG_LEVEL=INFO

# Phase 4 — optional real LLM (tests and default CLI use mock; no key required)
# LLM_PROVIDER=mock
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Phase 5 — API / UI / session storage
# SESSION_STORAGE_DIR=storage/sessions
# API_HOST=127.0.0.1
# API_PORT=8000
# UI_API_BASE_URL=http://127.0.0.1:8000
# DEFAULT_PROVIDER=mock
